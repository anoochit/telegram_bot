[model]
# Provider type: "gemini", "openai", or "thaillm"
provider = "gemini"
# The specific model identifier
model_name = "gemini-2.5-flash"
# The environment variable name that holds the API key (see .env.example)
api_key_env = "GOOGLE_API_KEY"

# Optional settings for OpenAI-compatible providers (like ThaiLLM)
# base_url = "https://api.openai.com/v1"
